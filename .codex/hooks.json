{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/yang/go-projects/stratum/.claude/hooks/guard-bash.sh"
          }
        ]
      },
      {
        "matcher": "Read|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/yang/go-projects/stratum/.claude/hooks/guard-fs.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/yang/go-projects/stratum/.claude/hooks/check-migration-tenant-tables.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/yang/.local/bin/headroom init hook ensure --profile init-stratum-8ec96697 --marker headroom-init-claude >/dev/null && echo '{\"continue\":true}'",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/yang/go-projects/stratum/.claude/hooks/go-quality.sh",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // .tool_response.filePath // \"\"'); if [[ -f \"$f\" && -x /usr/local/bin/shieldbot-mcp ]]; then /usr/local/bin/shieldbot-mcp \"$f\" 2>&1 | head -40 || true; fi",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "/home/yang/.local/bin/headroom init hook ensure --profile init-stratum-8ec96697 --marker headroom-init-claude >/dev/null && echo '{\"continue\":true}'",
            "timeout": 15
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/yang/go-projects/stratum/.codex/hooks/notify-windows.sh 'Codex 需要确认' '{project} · {message}'",
            "shell": "bash",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": []
  }
}
