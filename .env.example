# ClawHermes-AI-Go 环境变量示例
# 复制为 .env 并填写实际值，.env 不进 git

# 服务端口
PORT=8080

# PostgreSQL
POSTGRES_URL=postgres://clawhermes:clawhermes@localhost:5432/clawhermes?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# NATS JetStream
NATS_URL=nats://localhost:4222

# Milvus 向量数据库
MILVUS_HOST=localhost
MILVUS_PORT=19530

# Neo4j 图数据库
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_CAPTURE_CONTENT=false
OPIK_URL=
OPIK_OTLP_ENDPOINT=http://localhost:5173/api/v1/private/otel
OPIK_PROJECT=stratum
OPIK_WORKSPACE=default
OPIK_API_KEY=
TRACE_PAYLOAD_ENABLED=false
TRACE_PAYLOAD_ENDPOINT=localhost:9000
TRACE_PAYLOAD_ACCESS_KEY=
TRACE_PAYLOAD_SECRET_KEY=
TRACE_PAYLOAD_BUCKET=stratum-trace-evidence
TRACE_PAYLOAD_USE_TLS=false

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3002/auth/github/callback

# JWT RSA 私钥（godotenv 双引号多行格式，用 openssl genrsa 2048 生成）
# JWT_PRIVATE_KEY_PEM="<paste full PEM including BEGIN/END RSA PRIVATE KEY headers>"

# 全局管理员 GitHub 账号
GLOBAL_ADMIN_GITHUB_LOGIN=your-github-login

# 前端地址
FRONTEND_URL=http://localhost:3002

# HTTPS Cookie（生产环境改为 true）
SECURE_COOKIES=false

# LLM API key 由租户设置加密管理，不使用系统级环境变量。
# 以下地址仅在接入自托管 OpenAI-compatible endpoint 时配置；留空使用官方地址。
QWEN_BASE_URL=
ZHIPU_BASE_URL=

# Temporal
TEMPORAL_HOST_PORT=localhost:7233
TEMPORAL_NAMESPACE=clawhermes
TEMPORAL_TASK_QUEUE=agent-react
TEMPORAL_WORKER_MAX_ACTIVITIES=20
TEMPORAL_WORKER_MAX_WORKFLOWS=100
