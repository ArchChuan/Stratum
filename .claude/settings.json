{
  "env": {
    "GO_VERSION": "1.25",
    "DOCKER_BUILDKIT": "1",
    "COMPOSE_DOCKER_CLI_BUILD": "1",
    "GOPROXY": "https://goproxy.cn,direct"
  },
  "permissions": {
    "allow": [
      "Bash(go *)",
      "Bash(make *)",
      "Bash(docker *)",
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Read",
      "Edit",
      "Write"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(chown *)",
      "Bash(dd if=*)",
      "Bash(mkfs*)",
      "Bash(fdisk *)"
    ],
    "ask": [
      "Bash(docker-compose down)",
      "Bash(git push *)",
      "Bash(git reset --hard)",
      "Bash(make clean)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "echo '✓ Stratum 项目规范已加载 | 常用: make be-install · be-fmt · be-lint · be-test · infra-up | 护栏: PreToolUse deny(危险命令/敏感文件/prod.yaml/迁移越权) + PostToolUse(gofmt+vet)'",
            "statusMessage": "加载项目规范"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/guard-bash.sh",
            "statusMessage": "拦截危险命令"
          }
        ]
      },
      {
        "matcher": "Read|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/guard-fs.sh",
            "statusMessage": "文件系统访问保护"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/check-migration-tenant-tables.sh",
            "statusMessage": "迁移 tenant 表越权校验",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/go-quality.sh",
            "statusMessage": "gofmt + go vet",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // .tool_response.filePath // \"\"'); if [[ -f \"$f\" && -x /usr/local/bin/shieldbot-mcp ]]; then /usr/local/bin/shieldbot-mcp \"$f\" 2>&1 | head -40 || true; fi",
            "statusMessage": "shieldbot 安全扫描",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "sandbox": {
    "filesystem": {
      "denyWrite": [
        "/etc",
        "/sys",
        "/proc",
        "/dev",
        "/root",
        "/var/log",
        "/boot",
        "/usr/bin",
        "/usr/sbin"
      ],
      "denyRead": [
        "/root/.ssh",
        "/root/.aws",
        "/root/.kube",
        "/etc/shadow",
        "/etc/passwd",
        "/.aws/credentials"
      ]
    }
  },
  "worktree": {
    "bgIsolation": "none"
  }
}
